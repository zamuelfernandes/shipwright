# Shipwright web server listening port
PORT=8080

# Environment mode (development or production)
APP_ENV=development

# Docker Engine connection socket.
# The Docker SDK automatically detects this based on host configuration.
# Leave it commented to use default OS socket/pipe, or uncomment to override.

# Linux / macOS (Default)
DOCKER_HOST=unix:///var/run/docker.sock

# Windows Named Pipe (Default for Docker Desktop on Windows)
# DOCKER_HOST=npipe:////./pipe/docker_engine

# Remote Docker host over TCP (Secured or local network bridge)
# DOCKER_HOST=tcp://127.0.0.1:2375

# Remote Docker host over SSH
# DOCKER_HOST=ssh://user@remote-host-ip
